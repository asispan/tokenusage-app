<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LLMUsageMonitor" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.LLMUsageMonitor.Splash" parent="Theme.LLMUsageMonitor">
        <item name="android:windowSplashScreenBackground">@color/seed</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenAnimationDuration">300</item>
        <item name="android:postSplashScreenTheme">@style/Theme.LLMUsageMonitor</item>
    </style>
</resources>
